<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Library Book List</title>
    <style>
      *{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
     body {
        background-color: #fdf6f0;
        display: flex;
        align-items: center;
        justify-content: center;
     
        width: 100%;
        font-family: Arial, Helvetica, sans-serif;
        }
        .books-container {
          margin: 50px 0;
          display: flex;
          flex-direction: row;
          gap: 20px;
          flex-wrap: wrap;
          align-items: center;
          justify-content: center;
           width: 100%;
        }
        .book-card {
          background-color: white;
          padding: 20px;
          width: 500px;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          border-radius: 15px;
          box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        h2 {margin-bottom: 10px;}
        li {padding-bottom: 5px;}
    </style>
  </head>
  <body>
    <div class="books-container">
      <% for(let book of bookList) { %>
      <div class="book-card">
           <h2><%= book.title %></h2>
        <ul>
          <li><b>ID:</b> <%= book.id %></li>
          <li><b>Author:</b> <%= book.author %> </li>
          <li><b>Status:</b> <%= book.available %></li>
          <li><b>Created at:</b> <%= book.createdAt.slice(0,10) %></li>
          <li><b>Updated at:</b> <%= book.updatedAt.slice(0,10) %></li>
        </ul>
        </div>
       <% }%>
      
    </div>
  </body>
</html>